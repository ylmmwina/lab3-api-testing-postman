        {
          "name": "NEG 01 - GET non-existing post",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const maxResponseTime = Number(pm.environment.get('max_response_time'));",
                  "var responseBody = {};",
                  "try { responseBody = pm.response.json(); } catch (e) { responseBody = {}; }",
                  "pm.test('Status code indicates non-existing resource behavior', function () {",
                  "    pm.expect([200, 404]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Response time is less than max_response_time', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(maxResponseTime);",
                  "});",
                  "pm.test('Response body is empty object when resource does not exist', function () {",
                  "    pm.expect(responseBody).to.be.an('object');",
                  "    pm.expect(Object.keys(responseBody).length).to.eql(0);",
                  "});",
                  "console.log('NEG GET non-existing status:', pm.response.code);",
                  "console.log('NEG GET non-existing response time:', pm.response.responseTime);",
                  "console.log('NEG GET non-existing body:', responseBody);"
                ]
              }
            }
