{
  "info": {
    "_postman_id": "lab3-jsonplaceholder-collection",
    "name": "Lab3 JSONPlaceholder API Tests",
    "description": "Complex REST API testing for JSONPlaceholder using Postman and Newman.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Functional tests",
      "item": [
        {
          "name": "GET /posts - verify list of posts",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const maxResponseTime = Number(pm.environment.get('max_response_time'));",
                  "const expectedContentType = pm.environment.get('content_type');",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Content-Type is application/json; charset=utf-8', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.eql(expectedContentType);",
                  "});",
                  "",
                  "pm.test('Response time is less than max_response_time', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(maxResponseTime);",
                  "});",
                  "",
                  "const posts = pm.response.json();",
                  "",
                  "pm.test('Response body is an array', function () {",
                  "    pm.expect(posts).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Response contains at least 100 posts', function () {",
                  "    pm.expect(posts.length).to.be.at.least(100);",
                  "});",
                  "",
                  "pm.test('Each post has required structure', function () {",
                  "    posts.forEach(function (post) {",
                  "        pm.expect(post).to.have.property('userId');",
                  "        pm.expect(post).to.have.property('id');",
                  "        pm.expect(post).to.have.property('title');",
                  "        pm.expect(post).to.have.property('body');",
                  "",
                  "        pm.expect(post.userId).to.be.a('number');",
                  "        pm.expect(post.id).to.be.a('number');",
                  "        pm.expect(post.title).to.be.a('string');",
                  "        pm.expect(post.body).to.be.a('string');",
                  "    });",
                  "});",
                  "",
                  "if (posts.length > 0) {",
                  "    pm.environment.set('post_id', posts[0].id);",
                  "    pm.environment.set('user_id', posts[0].userId);",
                  "}",
                  "",
                  "console.log('Status:', pm.response.code);",
                  "console.log('Response time:', pm.response.responseTime);",
                  "console.log('First post ID:', posts[0] ? posts[0].id : null);",
                  "console.log('First user ID:', posts[0] ? posts[0].userId : null);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "posts"
              ]
            },
            "description": "Gets all posts and verifies status code, content type, response time, array type, minimum number of elements and object structure."
          },
          "response": []
        },
        {
          "name": "GET /posts - JSON Schema validation",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const maxResponseTime = Number(pm.environment.get('max_response_time'));",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response time is less than max_response_time', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(maxResponseTime);",
                  "});",
                  "",
                  "const postSchema = {",
                  "    type: 'object',",
                  "    required: ['userId', 'id', 'title', 'body'],",
                  "    properties: {",
                  "        userId: { type: 'number' },",
                  "        id: { type: 'number' },",
                  "        title: { type: 'string' },",
                  "        body: { type: 'string' }",
                  "    },",
                  "    additionalProperties: false",
                  "};",
                  "",
                  "const postsSchema = {",
                  "    type: 'array',",
                  "    minItems: 1,",
                  "    items: postSchema",
                  "};",
                  "",
                  "pm.test('Response matches posts JSON schema', function () {",
                  "    const posts = pm.response.json();",
                  "    pm.expect(posts).to.have.jsonSchema(postsSchema);",
                  "});",
                  "",
                  "const posts = pm.response.json();",
                  "",
                  "pm.test('Each post field has expected type', function () {",
                  "    posts.forEach(function (post) {",
                  "        pm.expect(post.userId).to.be.a('number');",
                  "        pm.expect(post.id).to.be.a('number');",
                  "        pm.expect(post.title).to.be.a('string');",
                  "        pm.expect(post.body).to.be.a('string');",
                  "    });",
                  "});",
                  "",
                  "console.log('Schema validation status:', pm.response.code);",
                  "console.log('Schema validation response time:', pm.response.responseTime);",
                  "console.log('Validated posts count:', posts.length);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "posts"
              ]
            },
            "description": "Validates posts response using JSON Schema and checks field types."
          },
          "response": []
        },
        {
          "name": "POST /posts - data driven create post",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const maxResponseTime = Number(pm.environment.get('max_response_time'));",
                  "const responseJson = pm.response.json();",
                  "",
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response time is less than max_response_time', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(maxResponseTime);",
                  "});",
                  "",
                  "pm.test('Response contains created post id', function () {",
                  "    pm.expect(responseJson).to.have.property('id');",
                  "    pm.expect(responseJson.id).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('Created post title matches test data', function () {",
                  "    pm.expect(responseJson.title).to.eql(pm.iterationData.get('title'));",
                  "});",
                  "",
                  "pm.test('Created post body matches test data', function () {",
                  "    pm.expect(responseJson.body).to.eql(pm.iterationData.get('body'));",
                  "});",
                  "",
                  "pm.test('Created post userId matches test data', function () {",
                  "    pm.expect(Number(responseJson.userId)).to.eql(Number(pm.iterationData.get('userId')));",
                  "});",
                  "",
                  "pm.environment.set('created_post_id', responseJson.id);",
                  "",
                  "console.log('POST status:', pm.response.code);",
                  "console.log('POST response time:', pm.response.responseTime);",
                  "console.log('Created post id:', responseJson.id);",
                  "console.log('Created title:', responseJson.title);",
                  "console.log('Created userId:', responseJson.userId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"{{title}}\",\n  \"body\": \"{{body}}\",\n  \"userId\": {{userId}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "posts"
              ]
            },
            "description": "Creates posts using external data file. The request body uses title, body and userId from JSON or CSV data file."
          },
          "response": []
        }
      ]
    },
