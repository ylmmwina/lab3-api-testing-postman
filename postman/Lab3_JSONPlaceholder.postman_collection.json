                  "const maxResponseTime = Number(pm.environment.get('max_response_time'));",
                  "const responseJson = pm.response.json();",
                  "",
                  "pm.test('Workflow POST status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Workflow POST response time is less than max_response_time', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(maxResponseTime);",
